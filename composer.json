{
    "name": "rbcs/appforge",
    "description": "A modern WordPress plugin starter framework with add-on architecture, PSR-4 autoloading, and React admin panels.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "RB Creative Solutions LLC",
            "homepage": "https://rbcreativesolutions.net"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.0",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "RBCS\\AppForge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RBCS\\AppForge\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpstan": "phpstan analyse",
        "test": "phpunit"
    }
}
